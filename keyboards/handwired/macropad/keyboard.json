{
    // ─────────────────────────────────────────────────────────────
    // keyboard.json — generated by QMK/Vial Wizard v5.6
    // Generated: 2026-07-13
    // Wizard:    https://www.robingosse.ca/qmkwizard
    // Author:    Robin Gosse
    //
    // This file is the single source of truth for all hardware config.
    // In modern QMK (2024+), keyboard.json replaces the old info.json.
    // Do NOT duplicate matrix pins, diode direction, or USB IDs in config.h.
    // ─────────────────────────────────────────────────────────────

    // What the OS will display as the USB device name
    "keyboard_name": "macropad",
    "manufacturer": "DIY",
    "maintainer": "Vinger",

    // USB identification — VID/PID pair must be unique per physical keyboard model.
    // 0xFEED is the QMK community default VID. Choose any unused PID.
    // These values must exactly match the vendorId/productId in vial.json.
    "usb": {
        "vid": "0xFEED",
        "pid": "0x0001",
        "device_version": "1.0.0"
    },

    // MCU (microcontroller) and bootloader.
    // processor: the chip identifier QMK uses internally.
    // bootloader: determines how the firmware is flashed.
    //   rp2040   → hold BOOTSEL while plugging in, drag .uf2 to the drive
    //   caterina → QMK Toolbox or avrdude (Pro Micro / Elite-C)
    //   stm32-dfu → QMK Toolbox or dfu-util
    "processor": "RP2040",
    "bootloader": "rp2040",

    // ── MATRIX WIRING ──────────────────────────────────────────────
    // rows: GPIO pins connected to the ROW wires on your PCB/hand-wire.
    //       Wire these to the anodes (or cathodes) of your diodes,
    //       depending on diode_direction below.
    // cols: GPIO pins connected to the COLUMN wires.
    // The order here must match the physical order on your board:
    //   rows[0] = ROW 0 (top row), rows[1] = ROW 1, etc.
    //   cols[0] = COL 0 (leftmost), cols[1] = COL 1, etc.
    
    "matrix_pins": {
        "rows": ["GP5", "GP4", "GP3"],
        "cols": ["GP6", "GP7", "GP8"]
    },

    // ── DIODE DIRECTION ────────────────────────────────────────────
    // ROW2COL: current flows ROW → diode → switch → COL
    //          Diode cathode (striped end / bar) connects toward the ROW wire.
    //          Diode anode connects toward the switch, COL connects other switch pin.
    // COL2ROW: opposite — current flows COL → diode → switch → ROW
    //          Diode cathode connects toward the COL wire.
    // This must match your physical PCB schematic exactly.
    "diode_direction": "ROW2COL",

    // ── FEATURES ──────────────────────────────────────────────────
    // nkro: N-Key Rollover — allows unlimited simultaneous keypresses (vs 6-key limit).
    // lto:  Link-Time Optimization — reduces firmware binary size significantly.
    //       Adds a few seconds to compile time but is always worth enabling.
    // split_keyboard: enables the split keyboard subsystem (serial transport etc).
    // ── DYNAMIC KEYMAP ────────────────────────────────────────────
    // layer_count: how many layers Via/Vial exposes. Each layer uses
    // rows × cols × 2 bytes of EEPROM. Default is 4.
    "dynamic_keymap": {
        "layer_count": 3
    },

    // ── LAYOUT ────────────────────────────────────────────────────
    // LAYOUT defines the mapping between physical key positions and matrix positions.
    // "matrix": [row, col] — which row/col intersection this key sits on.
    // "x", "y" — physical position in key units (1.0 = 1U = ~19mm).
    //            These came from your drag positions in the wizard designer.
    //            You can adjust them manually to fine-tune the visual representation
    //            in Vial's key picker.
    // For split keyboards: left half uses rows 0–2, right half uses rows 3–2.
    "layouts": {
        "LAYOUT": {
            "layout": [
        {"matrix": [0, 0], "x": 0.25, "y": 0.25},
        {"matrix": [0, 1], "x": 1.25, "y": 0.25},
        {"matrix": [0, 2], "x": 2.25, "y": 0.25},
        {"matrix": [1, 0], "x": 0.25, "y": 1.25},
        {"matrix": [1, 1], "x": 1.25, "y": 1.25},
        {"matrix": [1, 2], "x": 2.25, "y": 1.25},
        {"matrix": [2, 0], "x": 0.25, "y": 2.25},
        {"matrix": [2, 1], "x": 1.25, "y": 2.25},
        {"matrix": [2, 2], "x": 2.25, "y": 2.25}
            ]
        }
    }
}